{
	"name": "df_gold_hechos_ventas",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_ventas_consolidadas",
						"type": "DatasetReference"
					},
					"name": "ventasconsolidadas"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_canal",
						"type": "DatasetReference"
					},
					"name": "dimcanal"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_cliente",
						"type": "DatasetReference"
					},
					"name": "dimcliente"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_producto",
						"type": "DatasetReference"
					},
					"name": "dimproducto"
				},
				{
					"dataset": {
						"referenceName": "gold_dim_tiempo",
						"type": "DatasetReference"
					},
					"name": "dimtiempo"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "lookup1"
				},
				{
					"name": "lookup2"
				},
				{
					"name": "lookup3"
				},
				{
					"name": "lookup4"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id_transaccion_origen as string,",
				"          fecha_venta as timestamp,",
				"          codigo_producto as string,",
				"          nombre_producto_original as string,",
				"          cantidad as integer,",
				"          precio_unitario as decimal(18,2),",
				"          monto_total as decimal(18,2),",
				"          canal_venta as string,",
				"          cliente_nombre as string,",
				"          metodo_pago as string,",
				"          costo_envio as decimal(18,2),",
				"          fecha_carga as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> ventasconsolidadas",
				"source(output(",
				"          canal_key as integer,",
				"          nombre_canal as string,",
				"          tipo_canal as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimcanal",
				"source(output(",
				"          cliente_key as integer,",
				"          nombre_cliente as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimcliente",
				"source(output(",
				"          producto_key as integer,",
				"          codigo_producto as string,",
				"          nombre_producto as string,",
				"          categoria as string,",
				"          proveedor as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimproducto",
				"source(output(",
				"          fecha_key as integer,",
				"          fecha as date,",
				"          dia_semana as integer,",
				"          nombre_dia as string,",
				"          dia_mes as integer,",
				"          mes as integer,",
				"          nombre_mes as string,",
				"          trimestre as integer,",
				"          anio as integer,",
				"          es_fin_semana as boolean",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> dimtiempo",
				"ventasconsolidadas, dimcanal lookup(canal_venta == tipo_canal,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup1",
				"lookup1, dimcliente lookup(cliente_nombre == nombre_cliente,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup2",
				"lookup2, dimproducto lookup(nombre_producto_original == nombre_producto,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup3",
				"lookup3, dimtiempo lookup(fecha == fecha,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup4"
			]
		}
	}
}